# Backend API
BACKEND_API_URL=http://localhost:8080/api/v1

# SSO Configuration
SSO_CLIENT_ID=prebooking-backoffice
SSO_CLIENT_SECRET=your-secret-here
SSO_ISSUER_URL=https://sso.company.com/realms/main
SSO_REDIRECT_URI=http://localhost:3000/api/auth/callback

# Session
NUXT_SESSION_PASSWORD=minimum-32-characters-long-random-string

# App
NUXT_PUBLIC_APP_NAME=Prebooking Back Office

# Excel Processing
EXCEL_MAX_FILE_SIZE=52428800
EXCEL_CHUNK_SIZE=500
EXCEL_MAX_ROWS=100000
EXCEL_STREAM_THRESHOLD=5000

# Temp file storage
TEMP_UPLOAD_DIR=/tmp/prebooking-uploads
