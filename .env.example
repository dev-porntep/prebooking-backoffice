# ============================================================
# Prebooking Backoffice — Environment Variables
# Copy this file to .env and fill in the values
# ============================================================

# ── Backend ─────────────────────────────────────────────────
BACKEND_API_URL=http://localhost:8080

# ── Google OAuth (nuxt-auth-utils) ──────────────────────────
# Get these from: https://console.cloud.google.com/apis/credentials
# Authorized redirect URI must be: https://<your-domain>/auth/google
NUXT_OAUTH_GOOGLE_CLIENT_ID=
NUXT_OAUTH_GOOGLE_CLIENT_SECRET=

# ── Session ──────────────────────────────────────────────────
# Must be >= 32 characters — generate with: openssl rand -base64 32
NUXT_SESSION_PASSWORD=

# ── App ──────────────────────────────────────────────────────
# Set to false only for static builds (GitHub Pages preview)
NUXT_PUBLIC_AUTH_ENABLED=true

# Base URL — leave as / for Vercel/Railway/VPS
# Only change to /prebooking-backoffice/ for GitHub Pages
NUXT_APP_BASE_URL=/

# ── Logging ───────────────────────────────────────────────────
# LOG_TO_FILE=false   → stdout only (recommended for Docker/Vercel)
# LOG_TO_FILE=true    → also write rotating hourly files to LOG_PATH
LOG_PATH=logs/app
LOG_TO_FILE=false
LOG_LEVEL=info
LOG_CHANNEL=prebooking-backoffice
LOG_PRODUCT=backoffice
LOG_SERVICE_NAME=prebooking-backoffice
